{
  "name": "coralogix-dataprime-datasource",
  "version": "1.1.0",
  "description": "Coralogix DataPrime datasource for Grafana",
  "scripts": {
    "build": "webpack --env production && go build -o dist/gpx_coralogix-dataprime-datasource_$(go env GOOS)_$(go env GOARCH) ./pkg/",
    "build:backend": "go build -o dist/gpx_coralogix-dataprime-datasource_$(go env GOOS)_$(go env GOARCH) ./pkg/",
    "dev": "webpack --watch",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --forceExit --coverage",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@grafana/data": "^11.4.0",
    "@grafana/runtime": "^11.4.0",
    "@grafana/ui": "^11.4.0",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@testing-library/jest-dom": "^6.6.3",
    "babel-jest": "^29.7.0",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "monaco-editor": "^0.52.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.0",
    "webpack": "^5.96.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
