{
  "type": "datasource",
  "name": "Coralogix DataPrime",
  "id": "coralogix-dataprime-datasource",
  "module": "module.js",
  "metrics": true,
  "logs": true,
  "tracing": true,
  "backend": true,
  "executable": "gpx_coralogix-dataprime-datasource",
  "alerting": true,
  "info": {
    "description": "Query Coralogix Archive and Hot data using DataPrime syntax",
    "author": {
      "name": "Coralogix"
    },
    "keywords": ["coralogix", "dataprime", "logs", "traces"],
    "version": "1.1.0",
    "updated": "2026-05-19",
    "logos": {
      "small": "img/logo-32.svg",
      "large": "img/logo-128.svg"
    }
  },
  "dependencies": {
    "grafanaVersion": ">=11.0.0",
    "plugins": []
  },
  "routes": [
    {
      "path": "cx",
      "url": "{{ .JsonData.baseUrl }}/api",
      "headers": [
        {
          "name": "Authorization",
          "content": "Bearer {{ .SecureJsonData.apiKey }}"
        }
      ]
    }
  ]
}
